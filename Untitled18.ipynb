      "source": [
        "import numpy as np\n",
        "from scipy import stats\n",
        "\n",
        "# data\n",
        "x = np.array([1000,1100,1200,1300,1400,1500,1600,1700,\n",
        "              1800,1900,2000,2100,2200,2300,2400,2500])\n",
        "\n",
        "y_swiss = np.array([0.020,0.007,0.055,0.206,0.307,0.380,0.383,0.476,\n",
        "                    0.413,0.498,0.485,0.524,0.582,0.588,0.561,0.524])\n",
        "\n",
        "y_hcm = np.array([0.980,0.993,0.945,0.794,0.693,0.620,0.617,0.524,\n",
        "                  0.587,0.502,0.515,0.476,0.418,0.412,0.439,0.476])\n",
        "\n",
        "# regression swiss\n",
        "slope_s, intercept_s, r_s, p_s, se_s = stats.linregress(x,y_swiss)\n",
        "\n",
        "# regression hcm\n",
        "slope_h, intercept_h, r_h, p_h, se_h = stats.linregress(x,y_hcm)\n",
        "\n",
        "print(\"Swiss model\")\n",
        "print(\"slope =\", slope_s)\n",
        "print(\"intercept =\", intercept_s)\n",
        "print(\"R^2 =\", r_s**2)\n",
        "print(\"std error =\", se_s)\n",
        "print(\"t =\", slope_s/se_s)\n",
        "print(\"p =\", p_s)\n",
        "\n",
        "print(\"\\nHCM model\")\n",
        "print(\"slope =\", slope_h)\n",
        "print(\"intercept =\", intercept_h)\n",
        "print(\"R^2 =\", r_h**2)\n",
        "print(\"std error =\", se_h)\n",
        "print(\"t =\", slope_h/se_h)\n",
        "print(\"p =\", p_h)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import statsmodels.api as sm\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
   
        "file_path = \"/content/Book1.xlsx\"   ,
        "df = pd.read_excel(file_path)\n",
        "\n",
        
        "print(\"Columns in file:\")\n",
        "print(df.columns.tolist())\n",
        "\n",
    
        "x = df[\"Qe_tot\"]\n",
        "y_swiss = df[\"w_Swiss_average\"]\n",
        "y_hcm = df[\"w_HCM_average\"]\n",
        "\n",
       
        "def run_regression(x, y, y_name):\n",
        "    X = sm.add_constant(x)   # 添加截距项\n",
        "    model = sm.OLS(y, X).fit()\n",
        "\n",
        "    print(f\"\\n===== Regression: Qe_tot -> {y_name} =====\")\n",
        "    print(model.summary())\n",
        "\n",
        "    # 提取关键结果\n",
        "    intercept = model.params[\"const\"]\n",
        "    slope = model.params[\"Qe_tot\"]\n",
        "    t_value = model.tvalues[\"Qe_tot\"]\n",
        "    p_value = model.pvalues[\"Qe_tot\"]\n",
        "    r_squared = model.rsquared\n",
        "    std_err = model.bse[\"Qe_tot\"]\n",
        "\n",
        "    print(f\"\\nKey results for {y_name}:\")\n",
        "    print(f\"Intercept = {intercept:.6f}\")\n",
        "    print(f\"Slope     = {slope:.6f}\")\n",
        "    print(f\"Std Error = {std_err:.6f}\")\n",
        "    print(f\"t value   = {t_value:.6f}\")\n",
        "    print(f\"p value   = {p_value:.6e}\")\n",
        "    print(f\"R^2       = {r_squared:.6f}\")\n",
        "\n",
        "    return model\n",
        "\n",
        "# ===== 5. 分别回归 =====\n",
        "model_swiss = run_regression(x, y_swiss, \"w_Swiss_average\")\n",
        "model_hcm = run_regression(x, y_hcm, \"w_HCM_average\")\n",
        "\n",
        "# ===== 6. 为了画回归线，按 x 排序 =====\n",
        "df_plot = df.sort_values(\"Qe_tot\")\n",
        "x_plot = df_plot[\"Qe_tot\"]\n",
        "X_plot = sm.add_constant(x_plot)\n",
        "\n",
        "# ===== 7. 画图：Swiss =====\n",
        "plt.figure(figsize=(8, 5))\n",
        "plt.scatter(df[\"Qe_tot\"], df[\"w_Swiss_average\"], label=\"Data\")\n",
        "plt.plot(x_plot, model_swiss.predict(X_plot), label=\"Regression line\")\n",
        "plt.title(\"Qe_tot vs w_Swiss_average\")\n",
        "plt.xlabel(\"Qe_tot\")\n",
        "plt.ylabel(\"w_Swiss_average\")\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.show()\n",
        "\n",
        "# ===== 8. 画图：HCM =====\n",
        "plt.figure(figsize=(8, 5))\n",
        "plt.scatter(df[\"Qe_tot\"], df[\"w_HCM_average\"], label=\"Data\")\n",
        "plt.plot(x_plot, model_hcm.predict(X_plot), label=\"Regression line\")\n",
        "plt.title(\"Qe_tot vs w_HCM_average\")\n",
        "plt.xlabel(\"Qe_tot\")\n",
        "plt.ylabel(\"w_HCM_average\")\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.show()"
      ],
